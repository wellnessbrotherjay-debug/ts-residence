{
  "project_name": "TS Residence Website",
  "repo_url": "https://github.com/[repository-url]",
  "repo_role": "Website / acquisition layer",
  "status": "Development - basic functionality implemented, needs booking and user systems",
  "framework": "Next.js 16.2.1",
  "language": "TypeScript",
  "package_manager": "npm",
  "hosting": "Vercel",
  "database": "Supabase (PostgreSQL)",
  "orm": "Supabase client-side queries",
  "auth": "None implemented",
  "main_routes": [
    "/",
    "/apartments",
    "/contact",
    "/gallery",
    "/offers",
    "/faq",
    "/five-star-living",
    "/easy-living",
    "/healthy-living",
    "/admin"
  ],
  "api_routes": [
    {
      "path": "/api/leads",
      "methods": ["GET", "POST"],
      "purpose": "Lead capture with deduplication"
    },
    {
      "path": "/api/contact",
      "methods": ["POST"],
      "purpose": "Contact form submission"
    },
    {
      "path": "/api/chat",
      "methods": ["POST"],
      "purpose": "Chatbot responses"
    },
    {
      "path": "/api/chat/log",
      "methods": ["POST"],
      "purpose": "Chat message logging"
    },
    {
      "path": "/api/analytics/track",
      "methods": ["POST"],
      "purpose": "Analytics event tracking"
    },
    {
      "path": "/api/dashboard/summary",
      "methods": ["GET"],
      "purpose": "Dashboard summary metrics"
    },
    {
      "path": "/api/image",
      "methods": ["GET"],
      "purpose": "Image proxy with fallback"
    }
  ],
  "database_tables": [
    {
      "name": "chat_sessions",
      "purpose": "Chat widget session tracking",
      "fields": ["id", "created_at", "last_active", "user_agent", "ip_address"]
    },
    {
      "name": "chat_messages",
      "purpose": "Chat message history",
      "fields": ["id", "session_id", "role", "content", "created_at"]
    },
    {
      "name": "traffic_events",
      "purpose": "Analytics and user behavior tracking",
      "fields": ["id", "session_id", "visitor_id", "event_type", "page", "source", "medium", "campaign", "term", "content", "referrer", "gclid", "fbclid", "metadata", "created_at"]
    },
    {
      "name": "leads",
      "purpose": "Lead capture and CRM data",
      "fields": ["id", "first_name", "last_name", "email", "phone", "stay_duration", "message", "page", "source", "medium", "campaign", "term", "content", "referrer", "status", "metadata", "created_at"]
    }
  ],
  "events": [
    {
      "name": "page_view",
      "trigger": "Page load",
      "parameters": ["page_name", "page_path", "device_type", "search_params"]
    },
    {
      "name": "cta_click",
      "trigger": "Button/link click",
      "parameters": ["page_path", "link_url", "link_text", "device_type"]
    },
    {
      "name": "social_click",
      "trigger": "Social media link click",
      "parameters": ["page_path", "link_url", "link_text", "device_type"]
    },
    {
      "name": "nav_click",
      "trigger": "Navigation link click",
      "parameters": ["page_path", "link_url", "link_text", "device_type"]
    },
    {
      "name": "form_submit",
      "trigger": "Form submission",
      "parameters": ["page_path", "form_data", "device_type"]
    },
    {
      "name": "scroll_depth",
      "trigger": "User scrolls to milestone",
      "parameters": ["page_path", "depth", "device_type"]
    },
    {
      "name": "engaged_session",
      "trigger": "30 seconds on page",
      "parameters": ["page_path", "device_type"]
    }
  ],
  "webhooks": [],
